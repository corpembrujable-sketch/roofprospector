# ================================================================
# RoofProspector -- Environment Variables
# ================================================================
# LOCAL DEV:  copy this to .env.local and fill in your key
# PRODUCTION: add these in Vercel > Settings > Environment Variables

# ---- SERVER-SIDE key (never exposed to browser) ----
# Used by: api/maps.js (Geocoding API + Places Text Search)
# Restrict in GCP: no HTTP referrer restriction needed (server-side only)
GOOGLE_MAPS_API_KEY=AIzaSy_YOUR_KEY_HERE

# ---- CLIENT-SIDE key (loaded in browser for Places Autocomplete widget) ----
# Used by: src/lib/useGoogleMaps.js -> loads Maps JS SDK
# IMPORTANT: Restrict this key in GCP:
#   Application restrictions: HTTP referrers
#   Allowed: https://your-app.vercel.app/*  and  http://localhost:5173/*
#   API restrictions: Maps JavaScript API only
VITE_GOOGLE_MAPS_PUBLIC_KEY=AIzaSy_YOUR_KEY_HERE

# NOTE: You can use the same key for both, but using two separate keys
# with different restrictions is more secure.
